# Copy to .env and fill in real values. NEVER commit .env (AGENTS.md safety rules).

# --- Database (Neon/Supabase Postgres; sqlite fallback works for local dev) ---
DATABASE_URL=postgresql+asyncpg://PLACEHOLDER_USER:PLACEHOLDER_PASSWORD@PLACEHOLDER_HOST/PLACEHOLDER_DB
# DATABASE_URL=sqlite+aiosqlite:///./dev.db

# --- Redis (Upstash; local redis works too) ---
REDIS_URL=rediss://default:PLACEHOLDER_PASSWORD@PLACEHOLDER_HOST:6379
# REDIS_URL=redis://localhost:6379/0

# --- API ---
API_HOST=127.0.0.1
API_PORT=8000
API_BASE_URL=http://127.0.0.1:8000
# Shared secret between api and voice-worker for /internal endpoints.
INTERNAL_API_TOKEN=PLACEHOLDER_GENERATE_RANDOM_TOKEN

# --- Telegram bot (create via @BotFather) ---
TELEGRAM_BOT_TOKEN=PLACEHOLDER_TELEGRAM_BOT_TOKEN
# Comma-separated Telegram user IDs allowed to use the bot (your own ID).
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_OWNER_USER_ID=

# --- LLM (task normalization; optional - heuristic fallback without it) ---
ANTHROPIC_API_KEY=PLACEHOLDER_ANTHROPIC_API_KEY

# --- Stage 2: real calls (EPIC-002) ---
# simulate (stage-1 stub) | call (real Twilio/Pipecat; needs `uv sync --all-packages --extra call`)
WORKER_MODE=simulate
TWILIO_ACCOUNT_SID=PLACEHOLDER
TWILIO_AUTH_TOKEN=PLACEHOLDER
TWILIO_FROM_NUMBER=PLACEHOLDER_E164_SPANISH_NUMBER
# Public wss:// URL Twilio reaches the worker's /ws on (Cloudflare Tunnel in dev)
PUBLIC_WS_URL=wss://PLACEHOLDER_HOST/ws
WS_PORT=8765
DEEPGRAM_API_KEY=PLACEHOLDER
CARTESIA_API_KEY=PLACEHOLDER
CARTESIA_VOICE_ID=PLACEHOLDER
# Conversation LLM (OpenAI-compatible, swappable per D-5)
LLM_API_KEY=PLACEHOLDER
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=
# Crash recovery: fail runs silent for this many seconds (0 = off)
STALE_RUN_TIMEOUT_S=300
